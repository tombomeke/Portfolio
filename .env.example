# Copy this file to .env (never commit .env) for local reference.
# On production/shared hosting, set these as real environment variables in server config.

# =====================
# Portfolio database
# =====================
PORTFOLIO_DB_HOST=
PORTFOLIO_DB_NAME=
PORTFOLIO_DB_USER=
PORTFOLIO_DB_PASS=

# =====================
# ReadmeSync integration
# =====================
# Public generate endpoint used by ?page=readmesync and roadmap sync.
READMESYNC_API_URL=https://tombomekestudio.com/api/readmesync/generate

# Owner-only telemetry endpoints used by ?page=admin&section=telemetry.
READMESYNC_ADMIN_TELEMETRY_URL=https://tombomekestudio.com/api/v1/admin/telemetry
READMESYNC_ADMIN_TELEMETRY_EXPORT_URL=https://tombomekestudio.com/api/v1/admin/telemetry/export
READMESYNC_ADMIN_API_KEY=

# =====================
# Optional game API key
# =====================
R6STATS_API_KEY=
